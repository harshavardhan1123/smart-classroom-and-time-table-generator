# ──────────────────────────────────────────────────────────────
# UniSchedule — Environment Variables
# Copy this file to .env and fill in the values.
# ──────────────────────────────────────────────────────────────

# Flask Configuration (REQUIRED — app will crash on startup if missing)
FLASK_SECRET_KEY=
ADMIN_PASSWORD=

# Database Configuration
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306
DB_NAME=university_db

# SMTP Configuration (optional — OTPs print to console if not set)
SMTP_EMAIL=
SMTP_PASSWORD=

# OpenRouter AI (optional — chatbot disabled if not set)
OPENROUTER_API_KEY=
